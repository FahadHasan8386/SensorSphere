@page "/"
@using SensorSphereLearning.Component
@using SensorSphereLearning.Model
@using SensorSphereLearning.Services
@inject SensorService SensorService
@inject AppState AppState

<PageTitle>Dashboard - AtmoSync Agro Ai</PageTitle>

<h2 class="mb-4">📊 IoT Dashboard</h2>

<div class="row">
	<div class="col-md-4">
		<StatCard Title="Total Sensors" Value="@totalCount" CardColor="primary"/>
	</div>
	<div class="col-md-4">
		<StatCard Title="Total Sensors" Value="@onlineCount" CardColor="success" />
	</div>
	<div class="col-md-4">
		<StatCard Title="Total Sensors" Value="@offlineCount" CardColor="danger" />
	</div>
</div>
<h4 class="mt-4 mb-3">Recent Sensors</h4>

<SensorTable Sensors="recentSensors" ShowActions="false" />

@code{
	private List<Sensor> recentSensors = new();
	private int totalCount;
	private int onlineCount;
	private int offlineCount;

	protected override void OnInitialized()
	{
		LoadDashboardData();
	}
	private void LoadDashboardData()
	{
		var allSensors = SensorService.GetSensors();

		totalCount = allSensors.Count;
		onlineCount = allSensors.Count(s => s.IsOnline);
		offlineCount = allSensors.Count(s => !s.IsOnline);

		recentSensors = SensorService.GetRecentSensors(3);

		AppState.SetTotalSensors(totalCount);
	}
}