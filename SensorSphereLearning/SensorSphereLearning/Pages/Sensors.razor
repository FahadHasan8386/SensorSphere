@page "/sensors"
@using SensorSphereLearning.Model
@using SensorSphereLearning.Services
@inject SensorService SensorService
@inject AppState AppState

<PageTitle>Sensors - SensorSphere Learning</PageTitle>

<h2 class="mb-4">📋 Sensor List</h2>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Add New Sensor</h5>

        <div class="row g-2">
            <div class="col-md-4">
                <label class="form-label">Name</label>! -->
                <input class="form-control" @bind="newName" placeholder="e.g. DHT22" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Temperature (°C)</label>
                <input class="form-control" type="number" @bind="newTemperature" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Humidity (%)</label>
                <input class="form-control" type="number" @bind="newHumidity" />
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-primary w-100" @onclick="AddSensor">
                    Add Sensor
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <p class="text-danger mt-2 mb-0">@errorMessage</p>
        }
    </div>
</div>

<h4 class="mb-3">All Sensors</h4>
<SensorTable Sensors="allSensors"
             ShowActions="true"
             OnDeleteSensor="DeleteSensor"
             OnToggleStatus="ToggleStatus" />

@code {
    private List<Sensor> allSensors = new();

    // These fields are bound to the form inputs above using @bind.
    private string newName = string.Empty;
    private double newTemperature;
    private double newHumidity;

    private string errorMessage = string.Empty;

    protected override void OnInitialized()
    {
        RefreshSensorList();
    }

    private void RefreshSensorList()
    {
        allSensors = SensorService.GetSensors();
        AppState.SetTotalSensors(allSensors.Count);
    }

    private void AddSensor()
    {
        if (string.IsNullOrWhiteSpace(newName))
        {
            errorMessage = "Please enter a sensor name.";
            return;
        }

        errorMessage = string.Empty;

        SensorService.AddSensor(newName, newTemperature, newHumidity);

        newName = string.Empty;
        newTemperature = 0;
        newHumidity = 0;

        RefreshSensorList();
    }

}