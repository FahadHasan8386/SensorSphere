@page "/"
@attribute [Authorize]
@using sensorSphere.Components
@using sensorSphere.Models
@using sensorSphere.Services
@inject DeviceStateService DeviceService
@inject SensorStateService SensorService
@inject AlertStateService AlertService

<div class="container mt-4">
    <h2>Dashboard</h2>
    <DashboardStats OnlineCount="@onlineCount" OfflineCount="@offlineCount"
                    AvgTemp="@avgTemp" AvgHumidity="@avgHumidity"
                    LatestTime="@latestTime" AlertCount="@alertCount" />

    <div class="row mt-3">
        <div class="col-md-6">
            <h5>Top Alert</h5>
            @if (unacknowledgedAlerts.Any())
            {
                <div class="alert alert-warning">@unacknowledgedAlerts.First().Message</div>
            }
            else
            {
                <div class="alert alert-success">All clear!</div>
            }
        </div>
    </div>
</div>

@code {
    private int onlineCount, offlineCount, alertCount;
    private double avgTemp, avgHumidity;
    private string latestTime = string.Empty;
    private List<Alert> unacknowledgedAlerts = new();

    protected override void OnInitialized()
    {
        UpdateStats();
        DeviceService.OnChange += UpdateStats;
        SensorService.OnChange += UpdateStats;
        AlertService.OnChange += UpdateStats;
    }

    private void UpdateStats()
    {
        var devices = DeviceService.Devices;
        onlineCount = devices.Count(d => d.Status == "Online");
        offlineCount = devices.Count - onlineCount;

        var dhtReadings = devices
            .Select(d => SensorService.GetLatestReading(d.Id, "DHT22"))
            .Where(r => r != null).ToList();
        avgTemp = dhtReadings.Any() ? Math.Round(dhtReadings.Average(r => r.Temperature), 1) : 0;
        avgHumidity = dhtReadings.Any() ? Math.Round(dhtReadings.Average(r => r.Humidity), 1) : 0;

        var latest = SensorService.Readings.OrderByDescending(r => r.Timestamp).FirstOrDefault();
        latestTime = latest?.Timestamp.ToString("HH:mm") ?? "N/A";

        unacknowledgedAlerts = AlertService.Alerts.Where(a => !a.IsAcknowledged).ToList();
        alertCount = unacknowledgedAlerts.Count;

        InvokeAsync(StateHasChanged);
    }
}